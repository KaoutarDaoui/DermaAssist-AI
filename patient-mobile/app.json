{
  "expo": {
    "name": "Skin+ Patient",
    "slug": "dermassist-patient",
    "version": "1.0.0",
    "assetBundlePatterns": ["**/*"],
    "platforms": ["ios", "android", "web"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.dermassist.patient"
    },
    "android": {
      "package": "com.dermassist.patient",
      "permissions": ["CAMERA", "READ_EXTERNAL_STORAGE"]
    },
    "plugins": [["expo-image-picker"]]
  }
}
